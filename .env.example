# .env.example
OPENAI_API_KEY=sk-your-openai-key-here

# LLM Model Configuration (optional - defaults shown)
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

QDRANT_URL=http://localhost:6333
SQLITE_DB_PATH=./stats.db
LITELLM_PROXY_URL=http://localhost:4000
API_HOST_PORT=8001
STREAMLIT_HOST_PORT=8501
LITELLM_HOST_PORT=4000
QDRANT_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
QDRANT__TELEMETRY_DISABLED=true
LITELLM_LOCAL_MODEL_COST_MAP=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_SECRET_KEY=sk-lf-your-key
LANGFUSE_HOST=http://localhost:3000
MAX_UPLOAD_CHARS=500000
SIMILARITY_THRESHOLD=0.35
MAX_CHUNK_TOKENS=400
OVERLAP_TOKENS=50
N_RETRIEVAL_RESULTS=5

# PDF extraction controls
PDF_OCR_ENABLED=true
PDF_OCR_MIN_IMAGE_COUNT=1
PDF_OCR_RENDER_DPI=110
PDF_OCR_MAX_PAGES=5
PDF_OCR_MIN_TEXT_CHARS=40

# Optional multimodal extraction for charts, formulas, and diagrams
PDF_VISION_ENABLED=false
PDF_VISION_MODEL=gpt-4.1-mini
PDF_VISION_RENDER_DPI=110
PDF_VISION_MAX_PAGES=3
PDF_VISION_MIN_IMAGE_COUNT=1
PDF_VISION_MIN_TEXT_CHARS=80
PDF_VISION_TIMEOUT_SEC=12

LOG_LEVEL=INFO
